# ── MegatronBridge API — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Storage ─────────────────────────────────────────────────────────────────
# Root directory for all runtime data (DB, logs, checkpoints).
# Must be an absolute path. Created automatically if it does not exist.
DATA_DIR=/data

# SQLite database path (relative paths are resolved under DATA_DIR).
DATABASE_URL=sqlite+aiosqlite:///megatronbridge.db

# Root directory for model checkpoints.
CHECKPOINTS_ROOT=/data/checkpoints

# Root directory for job log files.
LOGS_ROOT=/data/logs

# HuggingFace model cache directory.
HF_CACHE_DIR=/data/hf_cache

# ── Worker ───────────────────────────────────────────────────────────────────
# Maximum number of concurrent GPU jobs (set to match your GPU count).
MAX_CONCURRENT_JOBS=1

# Dispatcher polling interval in seconds.
DISPATCHER_POLL_INTERVAL_S=2.0

# Comma-separated GPU indices to expose to worker processes.
# Example: "0,1,2,3" for the first 4 GPUs. Leave empty to use all.
CUDA_VISIBLE_DEVICES=0

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to a strong random secret to enable Bearer token authentication.
# Leave empty to disable auth (local/VPN-only use only).
# Generate a key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated). No wildcard by default.
# Example: "http://localhost:3000,https://myapp.example.com"
CORS_ORIGINS=http://localhost:3000

# ── Optional: S3 Checkpoint Storage ─────────────────────────────────────────
S3_ENABLED=false
# S3_BUCKET=my-checkpoints-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
